# Justfile for running tests across the monorepo
# Usage:
#   just test-all
#   just test <project> <env>


# Python versions to try for `test-all` (space-separated)
PY_VERSIONS := "3.10 3.11 3.12"

# Run pytest for a single project using `uv` to create the environment.
# uv installs the named workspace member (and all its local deps) as editable,
# then runs pytest scoped to that project's tests directory.
# Example: just test dissect.xfs 3.11
# Example: just test dissect.xfs 3.11 -- -k test_foo
test project env args="":
    uv run --package {{project}} --python {{env}} --group test pytest projects/{{project}} {{args}}

# Run pytest for every project and for each Python version in `PY_VERSIONS`.
# Skips directories that don't have a pyproject.toml.
test-all:
    @for d in projects/*; do \
        if [ -f "$d/pyproject.toml" ]; then \
            project_name=$(basename "$d"); \
            for py_version in {{PY_VERSIONS}}; do \
                echo "--- Running tests for $project_name with Python $py_version ---"; \
                just --justfile {{justfile()}} test $$project_name $$py_version; \
            done; \
        fi; \
    done
